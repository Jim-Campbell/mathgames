# Required
DATABASE_URL=postgres://localhost:5432/mathgames?sslmode=disable
MATHGAMES_API_KEY=changeme

# Optional — content generation disabled until set
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5
AI_MODEL=

# Optional — defaults to 8083
PORT=8083

# Optional — kid-message email delivery, off until SMTP_USER + SMTP_PASS are
# both set (messages are still saved either way). SMTP_PASS is a Google
# **App Password** (16 chars, requires 2FA on the account), NOT the Google
# account password. MESSAGE_TO defaults to SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MESSAGE_TO=
